@startuml
left to right direction
skinparam packageStyle rectangle

actor "Administrador (SGO)" as Admin
actor "Delegado do País" as Delegado
actor "Juiz da Prova" as Juiz
actor "Público / Imprensa" as Publico

package "SGO - Gestão das Olimpíadas" {
  usecase "UC01 - Autenticar no Sistema" as UC1
  usecase "UC02 - Cadastrar Delegação/País" as UC2
  usecase "UC03 - Cadastrar Atleta" as UC3
  usecase "UC04 - Gerenciar Local de Prova" as UC4
  usecase "UC05 - Cadastrar Competição/Modalidade" as UC5
  
  usecase "UC06 - Inscrever Atleta em Competição" as UC6
  usecase "UC07 - Validar Representação Exclusiva do País" as UC7
  
  usecase "UC08 - Alocar Local para Competição" as UC8
  usecase "UC09 - Validar Disponibilidade (Evitar Conflitos)" as UC9
  
  usecase "UC10 - Registrar Resultados da Prova" as UC10
  usecase "UC11 - Gerar Relatório de Quadro de Medalhas" as UC11
  usecase "UC12 - Consultar Cronograma de Provas" as UC12
}

Admin --> UC1
Admin --> UC2
Admin --> UC4
Admin --> UC5
Admin --> UC8

Delegado --> UC1
Delegado --> UC3
Delegado --> UC6

UC6 ..> UC7 : <<include>>
UC8 ..> UC9 : <<include>>

Juiz --> UC1
Juiz --> UC10

Publico --> UC11
Publico --> UC12
Admin --> UC11
@enduml
